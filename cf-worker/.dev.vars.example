# Copie para .dev.vars e preencha. Nunca commite .dev.vars.
#
# wrangler dev: variáveis aqui sobrescrevem [vars] do wrangler.toml com a mesma chave.
# Para admin em http://127.0.0.1:4000 falando com API em :8787, descomente:
# DEV_ORIGINS=http://127.0.0.1:4000,http://localhost:4000
# ADMIN_ORIGIN=http://127.0.0.1:4000
# COOKIE_DOMAIN=
# SKIP_AUTH_RATE_LIMIT=1

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_SECRET=
NETLIFY_DEPLOY_HOOK_URL=
BUILD_TOKEN=
MEDIA_BASE_URL=https://media.reversofilmes.com.br
